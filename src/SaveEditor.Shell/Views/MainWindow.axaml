<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SaveEditor.Shell.ViewModels"
        xmlns:abs="using:SaveEditor.Shell.Abstractions"
        x:Class="SaveEditor.Shell.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1000" Height="750"
        MinWidth="800" MinHeight="600">

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OnOpenClick" HotKey="Ctrl+O"
                          IsEnabled="{Binding SelectedGame, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <MenuItem Header="_Save" Click="OnSaveClick" HotKey="Ctrl+S"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <MenuItem Header="Save _As..." Click="OnSaveAsClick" HotKey="Ctrl+Shift+S"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#1E1E2E" Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#888"/>
        </Border>

        <!-- Game Selector Bar -->
        <Border DockPanel.Dock="Top" Padding="8,4" Background="#2A2A3E">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Game:" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Games}"
                          SelectedItem="{Binding SelectedGame}"
                          MinWidth="120">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="abs:IGamePlugin">
                            <TextBlock Text="{Binding GameName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Panel IsVisible="{Binding !IsFileLoaded}" >
            <TextBlock Text="Open an .SRM or .SAV file to begin editing (File > Open or Ctrl+O)"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" Foreground="#666"/>
        </Panel>

        <TabControl IsVisible="{Binding IsFileLoaded}"
                    ItemsSource="{Binding Slots}"
                    SelectedIndex="{Binding SelectedSlotIndex}"
                    Padding="8">
            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="abs:ISlotViewModel">
                    <TextBlock Text="{Binding Header}"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>
    </DockPanel>
</Window>
