<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FF4SaveEditor.Plugin.ViewModels"
             x:Class="FF4SaveEditor.Plugin.Views.InventoryView"
             x:DataType="vm:InventoryViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,6">
            <TextBlock Text="Sort:" VerticalAlignment="Center" FontWeight="Bold"/>
            <Button Content="Items First" Command="{Binding SortInventoryCommand}"
                    CommandParameter="{x:Static vm:InventorySortMode.ItemsFirst}" Padding="8,4"/>
            <Button Content="Weapons First" Command="{Binding SortInventoryCommand}"
                    CommandParameter="{x:Static vm:InventorySortMode.WeaponsFirst}" Padding="8,4"/>
            <Button Content="Armor First" Command="{Binding SortInventoryCommand}"
                    CommandParameter="{x:Static vm:InventorySortMode.ArmorFirst}" Padding="8,4"/>
            <Button Content="By ID" Command="{Binding SortInventoryCommand}"
                    CommandParameter="{x:Static vm:InventorySortMode.Default}" Padding="8,4"/>
            <Separator Width="1" Margin="4,0"/>
            <Button Content="Consolidate" Command="{Binding ConsolidateItemsCommand}" Padding="8,4"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  CanUserReorderColumns="False" CanUserSortColumns="False"
                  HeadersVisibility="Column" MaxHeight="400"
                  GridLinesVisibility="Horizontal" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding SlotNumber}" Width="40"/>
                <DataGridTemplateColumn Header="Item" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:InventorySlotViewModel">
                            <ComboBox ItemsSource="{Binding AllItems}"
                                      SelectedItem="{Binding SelectedItem}"
                                      HorizontalAlignment="Stretch" Margin="2">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Qty" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:InventorySlotViewModel">
                            <NumericUpDown Value="{Binding Quantity}" Minimum="0" Maximum="99"
                                           ShowButtonSpinner="False" HorizontalContentAlignment="Center"
                                           Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
