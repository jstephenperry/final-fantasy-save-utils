<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FF4SaveEditor.Plugin.ViewModels"
             xmlns:views="using:FF4SaveEditor.Plugin.Views"
             x:Class="FF4SaveEditor.Plugin.Views.SlotView"
             x:DataType="vm:SlotViewModel">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto">
        <!-- Gil + Max All Stats -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <TextBlock Text="Gil:" VerticalAlignment="Center" FontWeight="Bold"/>
            <NumericUpDown Value="{Binding Gil}" Minimum="0" Maximum="16777215"
                           FormatString="N0" Width="160"/>
            <Button Content="Best All Loadouts" Command="{Binding BestAllLoadoutsCommand}"/>
            <Button Content="Max All Stats" Command="{Binding MaxAllStatsCommand}"/>
        </StackPanel>

        <!-- Character list + editor -->
        <Grid Grid.Row="1" ColumnDefinitions="180,*">
            <!-- Character List -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Characters}"
                     SelectedItem="{Binding SelectedCharacter}"
                     Margin="0,0,8,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CharacterViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Level, StringFormat='Lv.{0}'}"
                                       Foreground="#888" IsVisible="{Binding !IsEmpty}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Character Editor -->
            <Border Grid.Column="1" Padding="8" CornerRadius="4">
                <ContentControl Content="{Binding SelectedCharacter}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:CharacterViewModel">
                            <views:CharacterView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <Separator Grid.Row="2" Margin="0,8"/>

        <!-- Inventory -->
        <Expander Grid.Row="3" Header="Inventory (48 slots)" IsExpanded="False">
            <views:InventoryView DataContext="{Binding Inventory}"/>
        </Expander>

        <Separator Grid.Row="4" Margin="0,8"/>

        <!-- Story Progress -->
        <Expander Grid.Row="5" Header="Story Progress" IsExpanded="True">
            <ScrollViewer MaxHeight="300">
                <ItemsControl ItemsSource="{Binding StoryProgress}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,2">
                                <TextBlock Text="[X]" IsVisible="{Binding Completed}"
                                           Foreground="#4CAF50" FontFamily="Consolas,Menlo,monospace"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="[ ]" IsVisible="{Binding !Completed}"
                                           Foreground="#666" FontFamily="Consolas,Menlo,monospace"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Description}" Foreground="#888"
                                           FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Expander>
    </Grid>
</UserControl>
